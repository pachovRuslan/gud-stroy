{
  "format": "custom",
  "id": "service",
  "label": "Услуга",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Slug (URL)",
          "placeholder": "frame-houses"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Название услуги",
          "placeholder": "Строительство каркасных домов",
          "useAsTitle": true
        }
      },
      "shortDescription": {
        "type": "Text",
        "config": {
          "label": "Краткое описание (для карточки и списка)",
          "placeholder": "Дома под ключ, реконструкция деревянных домов..."
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Главное изображение",
          "constraint": { "width": 800, "height": 600 },
          "thumbnails": []
        }
      },
      "characteristics": {
        "type": "Group",
        "config": {
          "label": "Характеристики (таблица на детальной странице)",
          "fields": {
            "label": {
              "type": "Text",
              "config": { "label": "Название характеристики" }
            },
            "value": {
              "type": "Text",
              "config": { "label": "Значение" }
            }
          }
        }
      },
      "fullDescription": {
        "type": "Group",
        "config": {
          "label": "Полное описание (абзацы)",
          "fields": {
            "paragraph": {
              "type": "Text",
              "config": { "label": "Абзац текста" }
            }
          }
        }
      },
      "gallery": {
        "type": "Group",
        "config": {
          "label": "Галерея изображений",
          "fields": {
            "image": {
              "type": "Image",
              "config": {
                "label": "Изображение галереи",
                "constraint": { "width": 800, "height": 600 },
                "thumbnails": []
              }
            }
          }
        }
      }
    }
  }
}
